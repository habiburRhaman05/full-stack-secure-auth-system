<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Reset your password</title>
  <style>
    body { margin:0; padding:0; background:#f4f7fb; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; }
    .container { max-width:600px; margin:40px auto; background:#fff; border-radius:12px; overflow:hidden; border:1px solid #e2e8f0; }
    .header { padding:24px; text-align:center; border-bottom:1px solid #e2e8f0; }
    .brand { font-size:20px; font-weight:700; color:#0f172a; }
    .content { padding:30px; color:#334155; }
    h2 { margin:0 0 10px; font-size:22px; color:#0f172a; }
    p { font-size:14px; line-height:1.6; margin:10px 0; }
    .button { display:inline-block; background:#2563eb; color:#fff !important; padding:12px 24px; border-radius:8px; text-decoration:none; font-weight:600; }
    .button-wrap { text-align:center; margin:25px 0; }
    .expiry { font-size:12px; color:#ef4444; margin-top:10px; text-align:center; }
    .box { background:#f8fafc; border:1px solid #e2e8f0; padding:12px; border-radius:8px; margin:20px 0; font-size:12px; word-break:break-all; }
    .footer { text-align:center; font-size:12px; color:#94a3b8; padding:20px; border-top:1px solid #e2e8f0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header"><div class="brand">Secure Authentication</div></div>
    <div class="content">
      <h2>Reset your password</h2>
      <p>Hi <strong><%= name %></strong>,</p>
      <p>We received a request to reset your password. Click the button below to continue:</p>
      <div class="button-wrap">
        <a class="button" href="<%= resetUrl %>">Reset password</a>
      </div>
      <div class="expiry">This link expires in <%= expiryMinutes %> minutes.</div>
      <p>If the button does not work, copy and paste the link below:</p>
      <div class="box"><%= resetUrl %></div>
      <p>If you did not request this, you can safely ignore this email.</p>
    </div>
    <div class="footer">© <%= new Date().getFullYear() %> All rights reserved.</div>
  </div>
</body>
</html>
