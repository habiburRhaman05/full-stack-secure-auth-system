<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Your 2FA code</title>
  <style>
    body { margin:0; padding:0; background:#f4f7fb; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; }
    .container { max-width:600px; margin:40px auto; background:#fff; border-radius:12px; overflow:hidden; border:1px solid #e2e8f0; }
    .header { padding:24px; text-align:center; border-bottom:1px solid #e2e8f0; }
    .brand { font-size:20px; font-weight:700; color:#0f172a; }
    .content { padding:30px; color:#334155; }
    h2 { margin:0 0 10px; font-size:22px; color:#0f172a; }
    p { font-size:14px; line-height:1.6; margin:10px 0; }
    .otp-box { text-align:center; margin:25px 0; }
    .otp { display:inline-block; background:#0f172a; color:#fff; font-size:28px; letter-spacing:6px; padding:14px 24px; border-radius:8px; font-weight:700; }
    .expiry { font-size:12px; color:#ef4444; margin-top:10px; }
    .footer { text-align:center; font-size:12px; color:#94a3b8; padding:20px; border-top:1px solid #e2e8f0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header"><div class="brand">Secure Authentication</div></div>
    <div class="content">
      <h2>Your two-factor authentication code</h2>
      <p>Hi <strong><%= name %></strong>,</p>
      <p>Use this code to complete your sign-in:</p>
      <div class="otp-box">
        <div class="otp"><%= otp %></div>
        <div class="expiry">Expires in <%= expiryMinutes %> minutes</div>
      </div>
      <p>If this was not you, change your password immediately.</p>
    </div>
    <div class="footer">© <%= new Date().getFullYear() %> All rights reserved.</div>
  </div>
</body>
</html>
