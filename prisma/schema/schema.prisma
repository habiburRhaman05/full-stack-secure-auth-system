generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid

  name     String  @db.VarChar(100)
  email    String  @unique @db.VarChar(255)
  password String? @db.Text

  emailVerified    Boolean  @default(false) @map("email_verified")
  totpSecret       String?  @map("totp_secret") @db.Text
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  backupCodes      String[] @default([]) @map("backup_codes")

  authProvider AuthProvider @default(local) @map("auth_provider")
  googleId     String?      @unique @map("google_id") @db.VarChar(255)

  role   UserRole   @default(customer)
  status UserStatus @default(active)

  avatarUrl String? @map("avatar_url")

  lastLoginAt DateTime? @map("last_login_at")
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions            Session[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]

  @@index([role])
  @@index([deletedAt])
  @@index([googleId])
  @@map("users")
}

model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  refreshToken String @unique @map("refresh_token") @db.Text
  jti          String @unique @db.VarChar(36)

  deviceInfo Json? @map("device_info")
  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent")

  isActive     Boolean       @default(true) @map("is_active")
  revokedAt    DateTime?     @map("revoked_at")
  revokeReason RevokeReason? @map("revoke_reason")

  expiresAt    DateTime @map("expires_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  type  VerificationType @default(email_verify)
  otp   String           @db.Text
  token String           @unique @db.VarChar(255)

  used      Boolean  @default(false)
  attempts  Int      @default(0) @db.SmallInt
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([token])
  @@map("email_verifications")
}

model PasswordReset {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  token String @unique @db.VarChar(255)

  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}
