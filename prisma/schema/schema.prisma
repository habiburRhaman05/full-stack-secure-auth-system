generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid

  name     String  @db.VarChar(100)
  username String? @unique @db.VarChar(50)
  email    String  @unique @db.VarChar(255)

  country  String? @db.VarChar(100)
  city     String? @db.VarChar(100)
  timezone String? @db.VarChar(60)
  locale   String  @default("en") @db.VarChar(10)

  role UserRole @default(customer)

  status    UserStatus
  banReason String?    @map("ban_reason")
  bannedAt  DateTime?  @map("banned_at")

  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by") @db.Uuid

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  account         Account?
  oauthProviders  OAuthProviderOptions[]
  sessions        Session[]
  customerProfile CustomerProfile?
  adminProfile    AdminProfile?
  passwordHistory PasswordHistory[]

  deletedBy    User?  @relation("DeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedUsers User[] @relation("DeletedBy")

  auditLogs    AuditLog[] @relation("AuditUser")
  auditActedBy AuditLog[] @relation("AuditActedBy")

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id String @id @db.Uuid

  authType AuthType @default(local) @map("auth_type")

  passwordHash      String?   @map("password_hash")
  passwordChangedAt DateTime? @map("password_changed_at")

  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")

  emailOtpHash       String?   @map("email_otp_hash")
  emailOtpExpiresAt  DateTime? @map("email_otp_expires_at")
  emailOtpAttempts   Int       @default(0) @map("email_otp_attempts") @db.SmallInt
  emailOtpLastSentAt DateTime? @map("email_otp_last_sent_at")

  resetTokenHash      String?   @map("reset_token_hash")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  resetRequestedAt    DateTime? @map("reset_requested_at")

  is2faEnabled  Boolean   @default(false) @map("is_2fa_enabled")
  totpSecret    String?   @map("totp_secret")
  totpEnabledAt DateTime? @map("totp_enabled_at")
  backupCodes   String[]  @map("backup_codes")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts") @db.SmallInt
  lastFailedLoginAt   DateTime? @map("last_failed_login_at")
  lockoutUntil        DateTime? @map("lockout_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([resetTokenHash])
  @@index([lockoutUntil])
  @@index([isEmailVerified])
  @@map("accounts")
}

model OAuthProviderOptions {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email") @db.VarChar(255)
  providerName   String?       @map("provider_name") @db.VarChar(100)
  providerAvatar String?       @map("provider_avatar")

  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  scopes         String[]

  linkedAt   DateTime  @default(now()) @map("linked_at")
  lastUsedAt DateTime? @map("last_used_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, providerUserId])
  @@map("oauth_providers")
}

model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  refreshTokenHash String  @map("refresh_token_hash")
  jti              String? @unique @db.VarChar(36)

  deviceId   String?     @map("device_id") @db.VarChar(100)
  deviceName String?     @map("device_name") @db.VarChar(200)
  deviceType DeviceType? @map("device_type")
  browser    String?     @db.VarChar(100)
  os         String?     @db.VarChar(100)


  ipAddress String? @map("ip_address")
  ipCountry String? @map("ip_country") @db.VarChar(100)
  ipCity    String? @map("ip_city") @db.VarChar(100)
  userAgent String? @map("user_agent")


  isActive     Boolean       @default(true) @map("is_active")
  revokedAt    DateTime?     @map("revoked_at")
  revokeReason RevokeReason? @map("revoke_reason")


  expiresAt    DateTime @map("expires_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")


  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([userId, isActive])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model CustomerProfile {
  userId String @id @map("user_id") @db.Uuid
    avatarUrl     String?   @map("avatar_url")
  bio           String?
  phoneNumber   String?   @map("phone_number") @db.VarChar(20)
  phoneVerified Boolean   @default(false) @map("phone_verified")
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("customer_profiles")
}

model AdminProfile {
  userId String @id @map("user_id") @db.Uuid

  department String? @db.VarChar(100)
  jobTitle   String? @map("job_title") @db.VarChar(100)
  employeeId String? @unique @map("employee_id") @db.VarChar(50)

  permissions    String[] @default([])
  canImpersonate Boolean  @default(false) @map("can_impersonate")
  accessLevel    Int      @default(1) @map("access_level") @db.SmallInt

  require2fa             Boolean   @default(true) @map("require_2fa")
  lastPermissionReviewAt DateTime? @map("last_permission_review_at")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accessLevel])
  @@map("admin_profiles")
}

model PasswordHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("password_history")
}

model AuditLog {
  id        BigInt  @id @default(autoincrement())
  userId    String? @map("user_id") @db.Uuid
  sessionId String? @map("session_id") @db.Uuid
  actedById String? @map("acted_by") @db.Uuid

  action     AuditAction
  status     AuditStatus @default(success)
  failReason String?     @map("fail_reason") @db.VarChar(100)

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  country   String? @db.VarChar(100)

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  user    User?    @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actedBy User?    @relation("AuditActedBy", fields: [actedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([actedById, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
